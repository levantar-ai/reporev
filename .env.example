# CORS proxy URL for git clone operations and OAuth token exchange
# Falls back to https://proxy.repo.guru if not set
VITE_CORS_PROXY_URL=https://proxy.repo.guru

# GitHub App client ID for "Sign in with GitHub" OAuth flow
# Create a GitHub App at https://github.com/settings/apps/new
# Permissions: Contents (read), Metadata (read)
VITE_GITHUB_CLIENT_ID=

# GitHub App slug (from your app's URL: github.com/apps/<slug>)
# Used for the "Manage Access" installation link
VITE_GITHUB_APP_SLUG=
